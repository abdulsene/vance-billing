# Vance Credit — Webhook service (stateless; no DATABASE_URL needed)

# CRC add-invoice-to-client endpoint. Leave UNSET to stub (log + return ok).
# This adds an invoice line only — never a subscription/billing plan.
# CRC_INVOICE_URL=https://your-crc-endpoint.example.com/clients/invoice

# Twilio SMS. Leave any UNSET to stub (log the would-send message + return ok).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM=+15555550000
