# Vance Credit — Enrollment service

# Postgres/Supabase. When set, uses PostgresStorage (apply clients_schema.sql first).
# When UNSET, runs in in-memory mode (fine for local dev/tests, not production).
DATABASE_URL=postgresql://user:password@host:5432/postgres

# NMI Customer Vault credentials.
NMI_SECURITY_KEY=your_nmi_security_key
NMI_ENDPOINT=secure.nmi.com

# Credit Repair Cloud create-client webhook (STUB target). Leave unset to skip.
# CRC_CREATE_CLIENT_WEBHOOK=https://your-crc-endpoint.example.com/clients
