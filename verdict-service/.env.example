# Vance Credit — Movement Verdict service
#
# DATABASE_URL: Postgres/Supabase connection string.
# When set, the service uses PostgresStorage (apply schema.sql first).
# When UNSET, the service runs in in-memory mode (data is lost on restart) —
# fine for local dev and tests, not for production.
DATABASE_URL=postgresql://user:password@host:5432/postgres
