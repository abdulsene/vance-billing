# Vance Credit — Billing API
#
# DATABASE_URL: Postgres/Supabase connection string. Point it at the SAME
# database the enrollment service writes vc_clients to. When set, uses
# PostgresStorage (apply dispatch_schema.sql first). When UNSET, runs in
# in-memory mode (fine for local dev/tests, not production).
DATABASE_URL=postgresql://user:password@host:5432/postgres
